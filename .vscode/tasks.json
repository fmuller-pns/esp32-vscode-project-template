{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "ESP-IDF - Build only",
            "type": "shell",
            "command": "idf.py build",
            "problemMatcher": ["$gcc"],
            "presentation": {
                "showReuseMessage": true,
                "reveal": "always",
                "panel": "shared",
                "clear": true,
                "focus": false
              }
        },
        {
            "label": "ESP-IDF - Flash and Monitor",
            "type": "shell",
            "command": "idf.py flash monitor",
            "problemMatcher": ["$gcc"],
            "presentation": {
                "showReuseMessage": true,
                "reveal": "always",
                "panel": "shared",
                "clear": true,
                "focus": true
              }
        },
        {
            "label": "ESP-IDF - Clean Project",
            "type": "shell", 
            "command": "idf.py fullclean",
            "problemMatcher": [],
            "presentation": {
                "showReuseMessage": false,
                "reveal": "always",
                "panel": "shared",
                "clear": false,
                "focus": false
              }
        },
        {
            "label": "ESP-IDF - Doxygen - HTML doc.",
            "type": "shell",
            "command": "doxygen",
            "problemMatcher": [],
            "presentation": {
                "showReuseMessage": true,
                "reveal": "always",
                "panel": "shared",
                "clear": true,
                "focus": false
              }
        }
    ]
}