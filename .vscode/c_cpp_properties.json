{
    "configurations": [
        {
            "name": "ESP32/ESP32-S3",
            "compilerPath": "${IDF_TOOLS_PATH}/xtensa-esp-elf/esp-15.2.0_20251204/xtensa-esp-elf/bin/xtensa-esp-elf-gcc",
            "compileCommands": "${workspaceFolder}/build/compile_commands.json",
            "intelliSenseMode": "linux-gcc-x64",
            "includePath": [
                "${workspaceFolder}/**",
                "${IDF_PATH}/components/**"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}",
                    "${IDF_PATH}/components/**"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        },
        {
            "name": "ESP32-C6",
            "compilerPath": "${IDF_TOOLS_PATH}/riscv32-esp-elf/esp-15.2.0_20251204/riscv32-esp-elf/bin/riscv32-esp-elf-gcc",
            "compileCommands": "${workspaceFolder}/build/compile_commands.json",
            "intelliSenseMode": "linux-gcc-x64",
            "includePath": [
                "${workspaceFolder}/**",
                "${IDF_PATH}/components/**"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}",
                    "${IDF_PATH}/components/**"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ],
    "version": 4
}
